# =============================================================================
# AGENT FACTORY — Environment Variables
# Stack: LangGraph + PydanticAI + o1/o3-mini/Phi-4 + Pinecone/Weaviate +
#        LangSmith/Arize Phoenix + Guardrails AI + Next.js HITL Dashboard
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in every value marked with <CHANGE_ME>
#   3. Never commit .env to version control
# =============================================================================

# --- Project ---
PROJECT_NAME=agent-factory
ENVIRONMENT=development
LOG_LEVEL=INFO

# =============================================================================
# INFERENCE — Multi-model setup (supervisor + worker models)
# =============================================================================
# Supervisor model (heavy reasoning)
SUPERVISOR_MODEL_PROVIDER=openai  # openai | anthropic | azure_ai_foundry
SUPERVISOR_MODEL=o3-mini          # o3-mini | o1 | claude-opus-4
SUPERVISOR_TEMPERATURE=1          # Fixed for o1/o3 reasoning models

# Worker model (fast extraction / tool calling)
WORKER_MODEL_PROVIDER=openai      # openai | anthropic | azure_ai_foundry
WORKER_MODEL=gpt-4o-mini          # gpt-4o-mini | claude-haiku-3-5 | phi-4
WORKER_TEMPERATURE=0.1

# OpenAI
OPENAI_API_KEY=<CHANGE_ME>
OPENAI_ORG_ID=<CHANGE_ME>         # Optional — your OpenAI org ID

# Anthropic
ANTHROPIC_API_KEY=<CHANGE_ME>

# Azure AI Foundry (alternative)
AZURE_AI_FOUNDRY_ENDPOINT=https://<CHANGE_ME>.services.ai.azure.com/models
AZURE_AI_FOUNDRY_API_KEY=<CHANGE_ME>
AZURE_AI_FOUNDRY_API_VERSION=2025-01-01-preview

# Inference parameters
INFERENCE_MAX_TOKENS=16384
INFERENCE_TIMEOUT_SECONDS=120
MAX_RETRIES=3

# =============================================================================
# ORCHESTRATION — LangGraph + PydanticAI
# =============================================================================
LANGGRAPH_CHECKPOINTER=postgres   # postgres | memory | redis
LANGGRAPH_MAX_RECURSION_LIMIT=50
LANGGRAPH_API_URL=http://localhost:8123
LANGGRAPH_API_KEY=<CHANGE_ME>

# Multi-agent configuration
MAX_AGENT_ROLES=10                # Max distinct agent roles in a workflow
AGENT_DEBATE_ROUNDS=3             # How many revision rounds agents perform
HITL_ENABLED=true                 # Human-in-the-loop approval gates
HITL_TIMEOUT_SECONDS=3600         # Time before HITL gate auto-times out

# =============================================================================
# VECTOR DATABASE — Pinecone or Weaviate
# =============================================================================
VECTOR_DB_PROVIDER=pinecone       # pinecone | weaviate

# Pinecone (serverless — recommended)
PINECONE_API_KEY=<CHANGE_ME>
PINECONE_ENVIRONMENT=gcp-starter  # e.g., gcp-starter | us-east-1-aws
PINECONE_INDEX_NAME=agent-factory-docs
PINECONE_DIMENSION=3072           # Match embedding model

# Weaviate (alternative — self-hosted or cloud)
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=<CHANGE_ME>
WEAVIATE_CLASS_NAME=AgentDocument

# Embedding model
EMBEDDING_MODEL=text-embedding-3-large  # OpenAI
EMBEDDING_DIMENSION=3072

# =============================================================================
# SECURITY — Guardrails AI
# =============================================================================
GUARDRAILS_ENABLED=true
GUARDRAILS_VALIDATION_MODE=strict # strict | lenient | audit
# Hub validators to apply (comma-separated)
GUARDRAILS_VALIDATORS=guardrails/nsfw_text,guardrails/detect_pii,guardrails/valid_json
GUARDRAILS_ON_FAIL=reask          # reask | fix | exception | noop

# =============================================================================
# OBSERVABILITY — LangSmith or Arize Phoenix
# =============================================================================
OBSERVABILITY_BACKEND=langsmith   # langsmith | arize-phoenix

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=<CHANGE_ME>
LANGCHAIN_PROJECT=agent-factory

# Arize Phoenix (self-hosted alternative)
PHOENIX_HOST=http://localhost:6006
PHOENIX_PROJECT_NAME=agent-factory
ARIZE_API_KEY=<CHANGE_ME>         # Only needed for Arize cloud

# OTel (forwarded to chosen backend)
OTEL_ENABLED=true
OTEL_SERVICE_NAME=agent-factory
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# =============================================================================
# FRONTEND — Next.js HITL Dashboard
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
NEXT_PUBLIC_APP_NAME=Agent Factory
NEXTAUTH_SECRET=<CHANGE_ME>
NEXTAUTH_URL=http://localhost:3001
# HITL dashboard refresh interval (ms)
NEXT_PUBLIC_HITL_POLL_INTERVAL=5000

# =============================================================================
# DATABASE — PostgreSQL (checkpointer + metadata)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_factory_db
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=<CHANGE_ME>
DATABASE_URL=postgresql://agent_user:<CHANGE_ME>@localhost:5432/agent_factory_db

# Redis (optional — for fast state caching)
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# API SERVER — FastAPI
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=4
API_SECRET_KEY=<CHANGE_ME>
API_CORS_ORIGINS=http://localhost:3001

# =============================================================================
# COMPLIANCE
# =============================================================================
COMPLIANCE_STANDARD=SOC2          # SOC2 | ISO27001 | GDPR
AUDIT_LOGGING_ENABLED=true
AGENT_DECISION_AUDIT_TRAIL=true   # Log every agent decision for auditability
